# B.I.O.M.A. — variáveis de ambiente
# ------------------------------------------------------------------
# COMO USAR:
#   1. Copie este arquivo para `.env`  (mesmo diretório)
#        PowerShell:  Copy-Item .env.example .env
#   2. Cole sua chave real do OpenRouter na linha abaixo (sem aspas).
#   3. Rode:  python run_elite_benchmark.py --check
#
# O arquivo `.env` está no .gitignore — NUNCA faça commit da chave.
# Pegue/gerencie sua chave em: https://openrouter.ai/keys
# ------------------------------------------------------------------

OPENROUTER_API_KEY=sk-or-cole-sua-chave-aqui