{
  "family": "bioma",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "4096",
  "runtimePlatform": { "cpuArchitecture": "X86_64", "operatingSystemFamily": "LINUX" },
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/bioma-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/bioma-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "bioma",
      "image": "<ACCOUNT_ID>.dkr.ecr.<REGION>.amazonaws.com/bioma:latest",
      "essential": true,
      "portMappings": [{ "containerPort": 8000, "protocol": "tcp" }],
      "environment": [
        { "name": "OMP_NUM_THREADS", "value": "1" },
        { "name": "MKL_NUM_THREADS", "value": "1" },
        { "name": "KMP_DUPLICATE_LIB_OK", "value": "TRUE" },
        { "name": "BIOMA_ALLOWED_ORIGINS", "value": "https://app.example.com" }
      ],
      "secrets": [
        {
          "name": "OPENROUTER_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:bioma/openrouter"
        }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "python -c \"import urllib.request,sys; sys.exit(0 if urllib.request.urlopen('http://127.0.0.1:8000/health',timeout=3).status==200 else 1)\""
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/bioma",
          "awslogs-region": "<REGION>",
          "awslogs-stream-prefix": "bioma"
        }
      }
    }
  ]
}
